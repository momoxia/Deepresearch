# Kimi API (Anthropic-compatible endpoint)
# Global: https://api.moonshot.ai/anthropic  |  Mainland China: https://api.moonshot.cn/anthropic
ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
ANTHROPIC_AUTH_TOKEN=your_kimi_api_key_here
ANTHROPIC_MODEL=kimi-k2.5

# Serper.dev search API (https://serper.dev)
SERPER_API_KEY=your_serper_api_key_here

# Firecrawl (optional, https://firecrawl.dev)
FIRECRAWL_API_KEY=

# Embedding (Aliyun DashScope, for semantic memory retrieval)
EMBEDDING_MODEL_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_API_KEY=your_dashscope_api_key_here
EMBEDDING_MODEL_NAME=text-embedding-v4

# Database — 相对路径依赖进程当前工作目录；生产/多入口启动建议写绝对路径，例如：
# sqlite+aiosqlite:////var/app/deepresearch.db
DATABASE_URL=sqlite+aiosqlite:///./deepresearch.db

# App
APP_TITLE=Deep Research Agent
APP_VERSION=0.1.0
APP_DEBUG=true

# HTTP server (match frontend VITE_API_PORT)
API_HOST=0.0.0.0
API_PORT=8808
# 进程数；>1 时关闭热重载。默认 SQLite 建议保持 1；换 PostgreSQL 后可 2–4+
# UVICORN_WORKERS=1

# PDF parsing (self-hosted MinerU service that turns a PDF URL into Markdown)
# Point this at your MinerU deployment; default assumes a local instance.
# PDF_PARSE_URL=http://127.0.0.1:8000/file_parse

# PDF vision (Kimi multimodal; images must be same-origin as PDF_PARSE_URL or data:image)
# PDF_VISION_MODEL=   # optional; default uses WEB_FETCH_SUMMARY_MODEL
# PDF_VISION_MAX_IMAGES=6
# PDF_VISION_MAX_IMAGE_BYTES=8388608
# PDF_VISION_MAX_EDGE=4096

# Memory
MEMORY_SUMMARY_THRESHOLD=10

# claude-agent-sdk 子进程的 config 目录（隔离 transcripts，避免污染 ~/.claude）
# 绝对或相对路径均可；相对路径基于进程 cwd。
CLAUDE_CONFIG_DIR=./.claude-runtime
